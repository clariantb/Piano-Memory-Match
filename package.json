{
  "name": "piano-memory-match",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "A music memory match game with multiple instruments, built with Svelte + TypeScript + Tone.js.",
  "scripts": {
    "dev": "vite",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "@tsconfig/svelte": "^5.0.4",
    "@types/canvas-confetti": "^1.9.0",
    "jsdom": "^25.0.1",
    "patch-package": "^8.0.1",
    "svelte": "^4.2.19",
    "svelte-check": "^4.0.5",
    "tslib": "^2.7.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  },
  "dependencies": {
    "canvas-confetti": "^1.9.3",
    "tone": "^15.0.4",
    "tonejs-instrument-cello-mp3": "^1.1.1",
    "tonejs-instrument-flute-mp3": "^1.1.2",
    "tonejs-instrument-guitar-acoustic-mp3": "^1.1.2",
    "tonejs-instrument-harp-mp3": "^1.1.1",
    "tonejs-instrument-saxophone-mp3": "^1.1.2",
    "tonejs-instrument-trumpet-mp3": "^1.1.2",
    "tonejs-instrument-violin-mp3": "^1.1.1",
    "tonejs-instrument-xylophone-mp3": "^1.1.2"
  }
}
